# ── JWT ──────────────────────────────────────────────────────────────
# 반드시 안전한 랜덤 값으로 교체하세요: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30

# ── Database ─────────────────────────────────────────────────────────
# Docker 컨테이너 내부 경로 (volume mount: ./data:/app/data)
DATABASE_URL=sqlite:///./data/gym_log.db

# ── CORS ─────────────────────────────────────────────────────────────
# 개발: * (모든 origin 허용)
# 프로덕션: 실제 도메인으로 교체 (쉼표로 여러 개 지정 가능)
# 예) CORS_ORIGINS=https://myapp.com,https://www.myapp.com
CORS_ORIGINS=*
